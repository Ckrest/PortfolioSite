#!/bin/bash
# Launch Claude Code in Systems directory with MCP server configured

ZAI_KEY_FILE="$HOME/.config/zai/api_key"

args=()
use_glm=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --glm)
      use_glm=true
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

cd ~/Systems

if [ "$use_glm" = true ]; then
    if [[ ! -f "$ZAI_KEY_FILE" ]]; then
      echo "Error: Z.AI API key not found at $ZAI_KEY_FILE"
      echo "Create it with: echo 'your-api-key' > $ZAI_KEY_FILE && chmod 600 $ZAI_KEY_FILE"
      exit 1
    fi

    export ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
    export ANTHROPIC_AUTH_TOKEN="$(cat "$ZAI_KEY_FILE")"
    export ANTHROPIC_API_KEY=""
    echo "Using Z.ai backend..."
fi

claude "${args[@]}"
